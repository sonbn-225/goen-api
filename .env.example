# Container/platform
PLATFORM=linux/amd64
CONTAINER_NAME=goen-api
SUNFLOWER_TZ=Asia/Ho_Chi_Minh

# HTTP
PORT=8080
API_DOMAIN=api.your-dev-domain.localhost
LOG_LEVEL=info

# Auth (JWT)
# In development, JWT_SECRET can be omitted (dev-insecure-secret will be used).
# In production, JWT_SECRET is required.
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=60

# Browser access (CORS)
# Dev default is '*', but setting explicitly helps when you switch to production.
CORS_ORIGINS=http://goen.localhost,http://localhost:5173,http://127.0.0.1:5173,http://api.goen.localhost

# Docker networks (must match sunflower-traefik and data network)
TRAEFIK_NETWORK=proxy_network
DATA_NETWORK=sunflower-data

# Dependencies (defaults assume your other stacks use these container_name values)
DATABASE_URL=postgres://postgres:your_strong_and_secret_password@sunflower-postgresql:5432/postgres?sslmode=disable
REDIS_URL=redis://default:your_strong_and_secret_password@sunflower-redis:6379/0
