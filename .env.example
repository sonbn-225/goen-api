# --- Environment for goen-api (Local Docker) ---

GOEN_ENV=development
TZ=Asia/Ho_Chi_Minh
PORT=8080
LOG_LEVEL=debug

# Database
# Using container name 'sunflower-postgresql' from the shared network
DATABASE_URL=postgres://postgres:92upOfL!A7TL@sunflower-postgresql:5432/postgres?sslmode=disable
MIGRATE_ON_START=true
MIGRATION_DIR=migrations

# Redis
REDIS_URL=redis://default:s0DuqI9imAH@sunflower-redis:6379/0

# Internal network service name for market data
MARKET_DATA_STATUS_URL=http://goen-market-data:8090/status

# SeaweedFS (S3)
SEAWEEDFS_ENDPOINT=sunflower-seaweedfs:8333
SEAWEEDFS_ACCESS_KEY_ID=your-s3-access-key
SEAWEEDFS_SECRET_ACCESS_KEY=your-s3-secret-key
SEAWEEDFS_BUCKET=goen
SEAWEEDFS_USE_SSL=false
SEAWEEDFS_PUBLIC_BASE_URL=http://s3.wisteria.local/goen

# Networks (Matching sunflower mono-repo default naming)
DATA_NETWORK=sunflower_data_network
TRAEFIK_NETWORK=proxy_network
GOEN_DOMAIN=api.wisteria.local

# JWT
JWT_SECRET=super-secret-key-for-local-dev
JWT_ACCESS_TTL_MINUTES=1440
